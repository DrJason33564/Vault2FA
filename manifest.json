{
  "manifest_version": 2,
  "name": "Vault2FA",
  "version": "1.1.0",
  "license": "MIT",
  "description": "A fine TOTP extension for Firefox with optional sync.",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "64": "icons/icon64.png",
    "96": "icons/icon96.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "storage",
    "clipboardWrite"
  ],
  "background": {
    "scripts": ["background.js"]
  },
  "browser_action": {
    "default_title": "Vault2FA",
    "default_popup": "popup.html"
  },
  "web_accessible_resources": [
    "qr-scanner-worker.min.js"
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "vault2fa@example.com",
      "strict_min_version": "104.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  }
}
